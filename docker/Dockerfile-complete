# Multi-stage build for small final image
FROM rust:1.75-slim AS builder

# Install build dependencies
RUN apt-get update && apt-get install -y \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Create app directory
WORKDIR /app

# Copy manifest files
COPY Cargo.toml Cargo.lock ./

# Create dummy source to cache dependencies
RUN mkdir src && echo "fn main() {}" > src/main.rs
RUN cargo build --release

# Now copy real source code
COPY src ./src

# Build for release (will use cached dependencies)
RUN cargo build --release

# Runtime stage
FROM debian:bookworm-slim

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -u 1000 calclaw
USER calclaw

# Copy binary from builder
COPY --from=builder /app/target/release/calclaw /usr/local/bin/calclaw

# Create data directory
RUN mkdir -p /home/calclaw/data
WORKDIR /home/calclaw

# Copy configuration
COPY config.toml ./config.toml

# Create necessary directories
RUN mkdir -p data/skills data/skill_templates data/skill_instances tts_cache logs

# Expose port
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:3000/health || exit 1

# Run application
CMD ["calclaw"]